# Default posture: this repo is for shareable dotfiles, not all of ~/.config.
*

# Root metadata and useful small config files.
!.gitignore
!README.md
!install.sh
!*-flags.conf
!mimeapps.list
!user-dirs.dirs
!user-dirs.locale
!QtProject.conf
!Trolltech.conf
!gtkrc
!gtkrc-2.0

# Current Hyprland rice.
!showcase/
!showcase/**
!hypr/
!hypr/**
!waybar/
!waybar/**
!rofi/
!rofi/**
!kitty/
!kitty/**
!fish/
!fish/**
!fastfetch/
!fastfetch/**
!mako/
!mako/**
!swaylock/
!swaylock/**
!xdg-desktop-portal/
!xdg-desktop-portal/**

# Editor and terminal tooling.
!nvim/
!nvim/**
!git/
!git/**
!btop/
!btop/**
!cava/
!cava/**
!tmux/
!tmux/**

# Theme/toolkit bits that affect the look.
!fontconfig/
!fontconfig/**
!gtk-3.0/
!gtk-3.0/**
!gtk-4.0/
!gtk-4.0/**
!qt5ct/
!qt5ct/**
!qt6ct/
!qt6ct/**
!Kvantum/
!Kvantum/**
!kvantum/
!kvantum/**
!color-schemes/
!color-schemes/**

# Optional launcher/terminal configs kept if present.
!foot/
!foot/**
!fuzzel/
!fuzzel/**
!ghostty/
!ghostty/**

# Never track recovery copies, generated state, or secrets inside allowed dirs.
*.bak
*.old
*.broken.*
**/*.bak
**/*.old
**/__pycache__/**
**/*.pyc
**/*token*
**/*secret*
**/Backups/**
**/Cache/**
**/CachedData/**
**/GPUCache/**
**/.git/**
